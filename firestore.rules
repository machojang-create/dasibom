rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 회원 프로필: 인증된 사용자만 접근
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // 자서전 데이터: 인증된 사용자만 접근
    // ⚠️ '본인(uid)만'으로 조이기 보류: 카카오/네이버 로그인이 익명 uid + socialId 매핑 구조라
    //   client가 users를 provider/socialId로 교차조회하고 다른 uid의 memoir를 병합함(handleSocialLogin).
    //   또 공개 서재(library)가 남의 isPublic 자서전을 읽음. 지금 조이면 로그인·서재 깨짐.
    //   → 로그인 병합을 Cloud Function(admin)으로 옮긴 뒤 조일 것 (release_blockers #2).
    match /memoirs/{userId} {
      allow read, write: if request.auth != null;
    }

    // 공유 자서전(공유링크 D-2): 링크 가진 사람은 읽기 / 생성·수정은 소유자만
    match /shared/{shareId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // 관리자 권한 신청·승인 (MVP) — 본인은 'pending' 신청만, 승인/거절/삭제는 master(운영사)만
    //   master = Firebase 토큰 이메일이 운영사 계정. 승인되면 admin.html이 role/orgId로 기능 게이트.
    //   ※ custom claims 업그레이드는 release_blockers #2(보안 리팩터)와 함께 나중에.
    match /admin_roles/{uid} {
      function isMaster() {
        return request.auth != null
          && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      }
      // 읽기: 본인 문서 또는 master(승인 큐 조회)
      allow read: if request.auth != null && (request.auth.uid == uid || isMaster());
      // 본인 신청·재신청: 자기 문서를 status='pending'·허용된 role로만 (승인상태는 못 건드림)
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.status == 'pending'
        && request.resource.data.role in ['org_admin', 'caregiver', 'viewer'];
      // master: 승인·거절·정지·삭제 전체
      allow read, write: if isMaster();
    }

    // 오늘의 지혜 — 한 줄 공감(커뮤니티). 누구나 읽기 / 인증 사용자가 짧은 글 작성 / 본인·운영자 삭제
    match /wisdom_comments/{cid} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 30
        && request.resource.data.day is string;
      allow update: if false;
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid
        || request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com']
      );
    }

    // 공용 한 줄 공감(서재·그때그시절·게임 등) — comments.js, scope 필드로 스레드 구분
    //   누구나 읽기 / 인증 사용자가 짧은 글 작성(본인 uid) / 본인·운영자 삭제
    match /comments/{cid} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 30
        && request.resource.data.scope is string
        && request.resource.data.scope.size() <= 80;
      allow update: if false;
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid
        || request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com']
      );
    }

    // AI 생성(자서전)·챗봇 일일 사용량 — Cloud Functions(Admin SDK)만 기록(규칙 우회), 관리자 통계만 조회
    match /usage_daily/{id} {
      allow read: if request.auth != null && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      allow write: if false;
    }
    match /usage_chat_daily/{id} {
      allow read: if request.auth != null && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      allow write: if false;
    }

    // 베타 설문(서프라이즈 자서전 직후) — 본인 작성만, 관리자 통계는 전체 조회
    match /survey/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com']);
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // 말동무 사전 — 즐겨찾기(나만의 앨범). 본인 것만 읽기·쓰기(기기 이전 시에도 유지)
    match /trendy_albums/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 말동무 사전 — 신조어 제보(커뮤니티). 누구나 읽기 / 본인 명의로 작성 /
    //   투표는 누구나 votes 필드만 ±1 — 본문(word/meaning/example) 변조 차단
    match /trendy_submissions/{sid} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.word is string && request.resource.data.word.size() > 0 && request.resource.data.word.size() <= 20
        && request.resource.data.meaning is string && request.resource.data.meaning.size() > 0 && request.resource.data.meaning.size() <= 60
        && request.resource.data.votes == 0;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes'])
        && (request.resource.data.votes == resource.data.votes + 1 || request.resource.data.votes == resource.data.votes - 1);
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid
        || request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com']
      );
    }
    // 신조어 제보 투표 기록 — 1인 1표(문서ID={제보ID}_{uid})로 중복투표 차단
    match /trendy_votes/{vid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}

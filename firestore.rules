rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 회원 프로필: 인증된 사용자만 접근
    //   ⚠️ '본인만'으로 못 조임 — handleSocialLogin이 provider/socialId로 남의 users를 교차조회함(아래 memoirs 주석 참고).
    //   단 아래 필드는 클라이언트가 절대 못 건드린다(서버=Functions만):
    //     · subscribed  — 결제 우회 방지(구독 상태)
    //     · dsbPoints    — 다시봄 포인트 잔액. 열어두면 누구나 무한 포인트 = 경제 붕괴
    //     · refToken     — 공유 식별 토큰
    //   → 쓰기는 Cloud Functions(Admin SDK, 규칙 우회)만.
    // ★2026-07-20 조임: 카카오/네이버가 커스텀 토큰(uid=kakao_/naver_+id) 로그인으로 전환 완료되어
    //   교차조회가 더는 필요 없음 → 본인+운영자만. (구버전 익명uid 데이터는 운영자가 수동 이관)
    match /users/{userId} {
      function isMasterUsr() {
        return request.auth != null
          && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      }
      allow read: if (request.auth != null && request.auth.uid == userId) || isMasterUsr();
      allow create: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.keys().hasAny(['subscribed', 'dsbPoints', 'refToken']);
      allow update: if isMasterUsr()
                    || (request.auth != null && request.auth.uid == userId
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscribed', 'dsbPoints', 'refToken']));
      allow delete: if isMasterUsr();
      // 게임 기록 등 하위컬렉션(brain_game 등)도 본인/운영자만
      match /{subpath=**} {
        allow read, write: if (request.auth != null && request.auth.uid == userId)
          || (request.auth != null
              && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com']);
      }
    }

    // ★2026-07-20 조임: 본인 + 공개서재(isPublic) 열람 + 운영자. 커스텀 토큰 전환으로 가능해짐.
    match /memoirs/{userId} {
      function isMasterMem() {
        return request.auth != null
          && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      }
      allow read: if (request.auth != null && request.auth.uid == userId)
                  || resource.data.isPublic == true
                  || isMasterMem();
      allow create, update: if (request.auth != null && request.auth.uid == userId) || isMasterMem();
      allow delete: if isMasterMem();
    }

    // 공유 자서전(공유링크 D-2): 링크 가진 사람은 읽기 / 생성·수정은 소유자만
    match /shared/{shareId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // 관리자 권한 신청·승인 (MVP) — 본인은 'pending' 신청만, 승인/거절/삭제는 master(운영사)만
    //   master = Firebase 토큰 이메일이 운영사 계정. 승인되면 admin.html이 role/orgId로 기능 게이트.
    //   ※ custom claims 업그레이드는 release_blockers #2(보안 리팩터)와 함께 나중에.
    match /admin_roles/{uid} {
      function isMaster() {
        return request.auth != null
          && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      }
      // 읽기: 본인 문서 또는 master(승인 큐 조회)
      allow read: if request.auth != null && (request.auth.uid == uid || isMaster());
      // 본인 신청·재신청: 자기 문서를 status='pending'·허용된 role로만 (승인상태는 못 건드림)
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.status == 'pending'
        && request.resource.data.role in ['org_admin', 'caregiver', 'viewer'];
      // master: 승인·거절·정지·삭제 전체
      allow read, write: if isMaster();
    }

    // ── 통합돌봄 PoC: 어르신 프로필(seniors) — 센터별 격리 ──────────────────
    //   B2B/B2G 실증용. L번호·건강데이터가 담기므로 센터 스태프(승인된 admin_role)만,
    //   그것도 자기 센터(orgId==centerId) 것만 접근. master는 전체.
    //   ⚠️ 실명 어르신 건강데이터를 대량 적재하기 전 release_blockers #2(서버권한 보안) 선행 필요.
    match /seniors/{sid} {
      function isMasterS() {
        return request.auth != null
          && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      }
      function roleDoc() {
        return get(/databases/$(database)/documents/admin_roles/$(request.auth.uid)).data;
      }
      function isApprovedStaff() {
        return request.auth != null
          && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
          && roleDoc().status == 'approved';
      }
      function myOrg() { return roleDoc().orgId; }
      allow read:   if isMasterS() || (isApprovedStaff() && resource.data.centerId == myOrg());
      allow create: if isMasterS() || (isApprovedStaff() && request.resource.data.centerId == myOrg());
      allow update, delete: if isMasterS() || (isApprovedStaff() && resource.data.centerId == myOrg());
    }

    // ── 통합돌봄 PoC: 개인정보(민감정보 포함) 수집·이용 동의(consents) ──────────
    //   보호자가 센터에서 받은 링크(/care-consent?center=)로 익명 접속해 제출.
    //   쓰기는 열려있되(보호자는 계정이 없음) 필드 검증으로 방어, 읽기는 그 센터 스태프/master만.
    match /consents/{cid} {
      function isMasterCN() {
        return request.auth != null
          && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      }
      function roleDocCN() {
        return get(/databases/$(database)/documents/admin_roles/$(request.auth.uid)).data;
      }
      function isApprovedStaffCN() {
        return request.auth != null
          && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
          && roleDocCN().status == 'approved';
      }
      function myOrgCN() { return roleDocCN().orgId; }
      allow create: if request.auth != null
        && request.resource.data.centerId is string && request.resource.data.centerId.size() > 0
        && request.resource.data.seniorName is string && request.resource.data.seniorName.size() > 0 && request.resource.data.seniorName.size() <= 20
        && request.resource.data.guardianName is string && request.resource.data.guardianName.size() > 0 && request.resource.data.guardianName.size() <= 20
        && request.resource.data.relation is string && request.resource.data.relation.size() <= 20
        && request.resource.data.phone is string && request.resource.data.phone.size() <= 20
        && request.resource.data.agreedGeneral == true
        && request.resource.data.agreedSensitive == true;
      allow read: if isMasterCN() || (isApprovedStaffCN() && resource.data.centerId == myOrgCN());
      allow update, delete: if isMasterCN();
    }

    // ── 통합돌봄 PoC: 대화 세션 기록(care_sessions) — 센터별 격리 ──────────────
    //   봄이-어르신 대화 로그 + AI 추출 지표(emotion_score/cognitive_category)가 담김.
    //   ⚠️ 공단 제출용으로 쓰려면 release_blockers #2 선행 + 복지사 검수(reviewed) 필수 — extraction은 참고용 지표.
    match /care_sessions/{sid} {
      function isMasterCS() {
        return request.auth != null
          && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      }
      function roleDocCS() {
        return get(/databases/$(database)/documents/admin_roles/$(request.auth.uid)).data;
      }
      function isApprovedStaffCS() {
        return request.auth != null
          && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
          && roleDocCS().status == 'approved';
      }
      function myOrgCS() { return roleDocCS().orgId; }
      allow read:   if isMasterCS() || (isApprovedStaffCS() && resource.data.centerId == myOrgCS());
      allow create: if isMasterCS() || (isApprovedStaffCS() && request.resource.data.centerId == myOrgCS());
      allow update: if isMasterCS() || (isApprovedStaffCS() && resource.data.centerId == myOrgCS());
      allow delete: if isMasterCS();
    }

    // ── 어르신 콘텐츠 이용 기록(care_usage) — 센터 리포트의 '팩트 지표' 원천 ────────
    //   어르신·카드·날짜별 1문서. 남는 건 카드명과 이용 시간뿐(대화 내용 아님).
    //   센터 태블릿이 그 센터 계정으로 로그인한 상태에서 기록 → 자기 센터 것만 쓰고 읽음.
    //   ※ 보호자 동의서(careconsent)의 '서비스 이용 기록' 항목이 이 데이터에 대한 동의.
    match /care_usage/{uid} {
      function isMasterCU() {
        return request.auth != null
          && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      }
      function roleDocCU() {
        return get(/databases/$(database)/documents/admin_roles/$(request.auth.uid)).data;
      }
      function isApprovedStaffCU() {
        return request.auth != null
          && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid))
          && roleDocCU().status == 'approved';
      }
      function myOrgCU() { return roleDocCU().orgId; }
      allow read:   if isMasterCU() || (isApprovedStaffCU() && resource.data.centerId == myOrgCU());
      allow create: if isMasterCU() || (isApprovedStaffCU() && request.resource.data.centerId == myOrgCU());
      allow update: if isMasterCU() || (isApprovedStaffCU() && resource.data.centerId == myOrgCU());
      allow delete: if isMasterCU();
    }

    // AI 토큰 실측(usage_ai_daily) — 원가 파악용 일별 집계.
    //   Functions(Admin SDK)만 기록, 운영 데이터라 master만 조회.
    match /usage_ai_daily/{day} {
      allow read:  if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      allow write: if false;
    }

    // ── 봄이 장기 기억(bom_memory) ──────────────────────────────────
    //   어르신이 들려준 '사실'(가족·건강·이력)이 쌓이는 민감 영역.
    //   쓰기는 Cloud Functions(Admin SDK)만 — 클라이언트가 기억을 조작하면
    //   봄이가 없는 사실을 아는 척하게 됨. 읽기도 본인만(디버그/노출용).
    match /bom_memory/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    // 기억 추출 일일 사용량 — Functions만 기록
    match /usage_mem_daily/{id} {
      allow read, write: if false;
    }

    // ── 자녀 안심 리포트 링크(family_links) ──────────────────────────
    //   토큰 문서 자체가 접근 열쇠라 클라이언트에 절대 열지 않음.
    //   생성=createFamilyLink, 열람=familyReport (둘 다 Functions/Admin).
    match /family_links/{token} {
      allow read, write: if false;
    }

    // ── 다시봄 포인트 엔진 — 전부 Functions(Admin)만. 클라가 손대면 무한 포인트 ──
    match /points_daily/{id} { allow read, write: if false; }
    match /points_spend/{id} { allow read, write: if false; }  // 꽃잎 소비 로그 — Functions 전용
    // 쪽지함(이벤트 꽃잎 지급) — 읽기는 본인만, 쓰기·수령 처리는 Functions 전용(adminSendMail/claimMail)
    match /mailbox/{uid}/msgs/{mid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
    match /ref_links/{token} { allow read, write: if false; }
    match /referrals/{rid}   { allow read, write: if false; }

    // ── 유입/전환 집계(traffic_daily) — 조작 방지 위해 Functions(logTraffic)만 씀 ──
    match /traffic_daily/{day} {
      allow read:  if request.auth != null
                   && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      allow write: if false;
    }

    // AI 발화분석(통합돌봄) 일일 사용량 — Cloud Functions(Admin SDK)만 기록, 마스터만 조회
    match /usage_care_daily/{id} {
      allow read: if request.auth != null && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      allow write: if false;
    }

    // 오늘의 지혜 — 한 줄 공감(커뮤니티). 누구나 읽기 / 인증 사용자가 짧은 글 작성 / 본인·운영자 삭제
    // 운영자는 봇 uid(bot_*)로도 작성 가능(봇 심기)
    match /wisdom_comments/{cid} {
      function isMasterWC() {
        return request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      }
      allow read: if true;
      allow create: if request.auth != null
        && (request.resource.data.uid == request.auth.uid
            || (isMasterWC() && request.resource.data.uid.matches('bot_.*')))
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 30
        && request.resource.data.day is string;
      allow update: if false;
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid
        || request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com']
      );
    }

    // ── 아재퀴즈(gag) 전용 — AI스튜디오 외부 프로젝트에서 이관(2026-07-20). 스키마가 공용 comments와 달라 분리 ──
    // 주의: gag 앱의 userId는 firebase uid가 아니라 기기 로컬 랜덤 ID(localStorage.localUserId)라
    //       uid 일치 검사 불가 — 인증 존재 + 필드 타입/크기 제한으로 방어(민감정보 아님).
    match /gag_favorites/{id} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.userId is string
        && request.resource.data.userId.size() <= 40;
      allow delete: if request.auth != null;
    }
    match /gag_history/{id} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.userId is string
        && request.resource.data.userId.size() <= 40;
      allow delete: if false;
    }
    match /gag_comments/{id} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 300
        && request.resource.data.jokeId is string
        && request.resource.data.jokeId.size() <= 80;
      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }

    // ── 토론장 사랑방 공유(2026-07-23, 파일럿 공유 백엔드 1단계) ──
    // 댓글은 100자라 공용 comments(30자 제한)와 분리. 날짜(scope)별 스레드.
    match /debate_comments/{cid} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 120
        && request.resource.data.scope is string
        && request.resource.data.scope.size() <= 40
        && request.resource.data.side in ['A', 'B']
        && request.resource.data.author is string
        && request.resource.data.author.size() <= 24;
      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }
    // 날짜별 공유 추임새(얼씨구·난리났네 등 5종) — 투표함과 같은 증가 전용 규칙
    match /debate_reacts/{day} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.eolssigu is int && request.resource.data.nanli is int
        && request.resource.data.aigo is int && request.resource.data.ehem is int
        && request.resource.data.giga is int;
      allow update: if request.auth != null
        && request.resource.data.eolssigu >= resource.data.eolssigu && request.resource.data.eolssigu <= resource.data.eolssigu + 3
        && request.resource.data.nanli >= resource.data.nanli && request.resource.data.nanli <= resource.data.nanli + 3
        && request.resource.data.aigo >= resource.data.aigo && request.resource.data.aigo <= resource.data.aigo + 3
        && request.resource.data.ehem >= resource.data.ehem && request.resource.data.ehem <= resource.data.ehem + 3
        && request.resource.data.giga >= resource.data.giga && request.resource.data.giga <= resource.data.giga + 3;
      allow delete: if false;
    }
    // 날짜별 공유 투표함 — 증가만 허용(한 번에 최대 +3), 감소·널뛰기 금지
    match /debate_votes/{day} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.A is int && request.resource.data.B is int
        && request.resource.data.A >= 0 && request.resource.data.B >= 0
        && request.resource.data.A <= 5000 && request.resource.data.B <= 5000;
      allow update: if request.auth != null
        && request.resource.data.A is int && request.resource.data.B is int
        && request.resource.data.A >= resource.data.A
        && request.resource.data.B >= resource.data.B
        && request.resource.data.A <= resource.data.A + 3
        && request.resource.data.B <= resource.data.B + 3;
      allow delete: if false;
    }

    // 공용 한 줄 공감(서재·그때그시절·게임 등) — comments.js, scope 필드로 스레드 구분
    // 운영자는 봇 uid(bot_*)로도 작성 가능(봇 심기)
    match /comments/{cid} {
      function isMasterC() {
        return request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      }
      allow read: if true;
      allow create: if request.auth != null
        && (request.resource.data.uid == request.auth.uid
            || (isMasterC() && request.resource.data.uid.matches('bot_.*')))
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 30
        && request.resource.data.scope is string
        && request.resource.data.scope.size() <= 80;
      allow update: if false;
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid
        || request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com']
      );
    }

    // AI 생성(자서전)·챗봇 일일 사용량 — Cloud Functions(Admin SDK)만 기록(규칙 우회), 관리자 통계만 조회
    match /usage_daily/{id} {
      allow read: if request.auth != null && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      allow write: if false;
    }
    match /usage_chat_daily/{id} {
      allow read: if request.auth != null && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      allow write: if false;
    }
    // 봄이 음성(TTS) 일일 사용량 — Cloud Functions(Admin SDK)만 기록
    match /usage_tts_daily/{id} {
      allow read: if request.auth != null && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      allow write: if false;
    }
    // 봄이 음성 캐시 — Cloud Functions(Admin SDK)만 읽고 씀(클라는 함수 통해서만 오디오 받음)
    match /tts_cache/{id} {
      allow read, write: if false;
    }

    // 베타 설문(서프라이즈 자서전 직후) — 본인 작성만, 관리자 통계는 전체 조회
    match /survey/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com']);
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // 말동무 사전 — 즐겨찾기(나만의 앨범). 본인 것만 읽기·쓰기(기기 이전 시에도 유지)
    match /trendy_albums/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 말동무 사전 — 신조어 제보(커뮤니티). 누구나 읽기 / 본인 명의로 작성 /
    //   투표는 누구나 votes 필드만 ±1 — 본문(word/meaning/example) 변조 차단
    match /trendy_submissions/{sid} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.word is string && request.resource.data.word.size() > 0 && request.resource.data.word.size() <= 20
        && request.resource.data.meaning is string && request.resource.data.meaning.size() > 0 && request.resource.data.meaning.size() <= 60
        && request.resource.data.votes == 0;
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes'])
        && (request.resource.data.votes == resource.data.votes + 1 || request.resource.data.votes == resource.data.votes - 1);
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid
        || request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com']
      );
    }
    // 신조어 제보 투표 기록 — 1인 1표(문서ID={제보ID}_{uid})로 중복투표 차단
    match /trendy_votes/{vid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // 공지사항 — 누구나 읽기, 마스터만 작성/수정/삭제
    match /notices/{nid} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }

    // 이벤트 배너 — 누구나 읽기, 마스터만 관리
    match /event_banners/{bid} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }

    // 이벤트 팝업(진입 모달) — 누구나 읽기, 마스터만 관리
    match /popups/{pid} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }

    // 쿠폰 — 인증 사용자 읽기(검증용), 마스터만 관리
    match /coupons/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }

    // 공개서재 좋아요 — 누구나 읽기, 본인 것만 생성/삭제 (문서ID={memoirId}_{uid})
    match /library_likes/{lid} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // 공개서재 댓글 — 누구나 읽기, 인증 사용자 작성(짧은 글), 본인·마스터 삭제
    match /library_comments/{lcid} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 50;
      allow update: if false;
      allow delete: if request.auth != null && (
        resource.data.uid == request.auth.uid
        || request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com']
      );
    }

    // 댓글 신고 — 인증 사용자 신고 작성, 마스터만 조회·처리
    match /comment_reports/{rid} {
      allow read: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }

    // 감정 표현 반응 — 콘텐츠별 이모지 카운트(reactions/{scope}). 누구나 읽기,
    // 인증 사용자는 허용된 감정 키만 +1씩(다른 필드 못 건드림). 삭제는 마스터만.
    match /reactions/{scope} {
      function reactKeysOk() {
        return request.resource.data.keys().hasOnly(
          ['like','warm','touched','happy','funny','best','thanks','cheer']);
      }
      allow read: if true;
      allow create: if request.auth != null && reactKeysOk();
      allow update: if request.auth != null && reactKeysOk()
        && request.resource.data.diff(resource.data).affectedKeys().size() == 1;
      allow delete: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }

    // 봄이네 사랑방(맞고 등 보드게임) 누적 전적·포인트 — 문서ID=uid, 게임별 필드 확장 구조
    // { matgo:{points,wins,losses,draws}, janggi:{...} } — 누구나 읽기(랭킹 대비), 본인만 쓰기
    match /game_stats/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }

    // ── 시니어 직업 상담소(jobs.html) 2026-07-23 ──────────────────────
    // 전화 상담 신청 — 전화번호(개인정보)가 담기므로 읽기는 마스터만.
    // 작성은 인증 사용자(익명 포함) 본인 명의 1건씩, 필드 타입·크기 검증으로 방어.
    match /job_consults/{cid} {
      allow read: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 20
        && request.resource.data.phone is string && request.resource.data.phone.size() >= 9 && request.resource.data.phone.size() <= 20
        && request.resource.data.jobTitle is string && request.resource.data.jobTitle.size() <= 80
        && request.resource.data.career is string && request.resource.data.career.size() <= 60
        && request.resource.data.region is string && request.resource.data.region.size() <= 10;
      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }
    // 워크넷 공고 캐시 — Cloud Functions(jobSearch, Admin SDK)만 읽고 씀
    match /jobs_cache/{id} {
      allow read, write: if false;
    }

    // 추억의 오락실 — 주간 랭킹·명예의 전당. 문서ID={weekNum}_{game}_{uid}(유저당 주간 1건, 최고점만 갱신)
    // 누구나 읽기(랭킹·명예의 전당 열람), 본인 uid로만 쓰기·갱신. 삭제는 마스터만.
    match /arcade_scores/{sid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.game in ['blast','match3','bubble']
        && request.resource.data.score is number
        && request.resource.data.score >= 0 && request.resource.data.score <= 999999
        && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 10
        && request.resource.data.weekNum is number;
      allow delete: if request.auth != null
        && request.auth.token.email in ['machojang@gmail.com', 'machojang@naver.com'];
    }
  }
}
